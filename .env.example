# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional error monitoring
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com
# DATADOG_SERVICE=gentle-stream
# Optional override for crossword clue calls (default: claude-sonnet-4-20250514).
# ANTHROPIC_CROSSWORD_MODEL=claude-3-5-sonnet-20241022
#
# Crossword clues: default is Wiktionary + Datamuse (no LLM). Set to use Claude:
# CROSSWORD_CLUES_SOURCE=anthropic

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# MUST be publishable (sb_publishable_...) or legacy anon JWT — never sb_secret_ or service_role.
# Supabase blocks secret keys from browsers (User-Agent); magic-link POST /auth/v1/otp returns 401.
# Legacy: anon JWT. New keys: Dashboard → Settings → API → Publishable.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here

# Server-only — secret key (sb_secret_...) or legacy service_role JWT. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: bypass auth middleware + login (local dev only). Never set in production.
# AUTH_DISABLED=1
# DEV_USER_ID=dev-local
# Skip live ingest/tagger on empty feed (pairs with DEV_LIGHT in AGENTS.md for auth-free dev).
# DEV_LIGHT=1

# Production: OAuth redirect hint when SSR runs (dev ignores this and uses localhost:3000
# unless NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN is set). Set on Vercel to your canonical URL.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional OAuth/magic-link origin override when there is no browser (rare). The login UI
# uses window.location.origin for redirect_to so PKCE cookies match the address bar (LAN IP,
# non-default port, etc.). Supabase Redirect URLs must include that same origin, e.g.
# http://192.168.1.10:3000/**
#
# Optional explicit override (tunnels, etc.). Supabase must allow that URL in:
# Dashboard → Authentication → URL Configuration → Redirect URLs.
# Use http://localhost:3000/** (globstar) — http://localhost:3000/* matches only ONE path
# segment, so it does NOT match /auth/callback and Supabase falls back to Site URL (production).
# If redirect links alternate between localhost and production, verify:
# 1) Site URL is your canonical production URL
# 2) every development origin is listed
# 3) wildcard uses /**, not /*
# See https://supabase.com/docs/guides/auth/redirect-urls
# NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=http://localhost:3000

# Shown on /data-deletion as mailto for “delete my data” (Meta User data deletion URL, etc.).
# NEXT_PUBLIC_SUPPORT_EMAIL=you@yourdomain.com

# Optional legal docs date label used by /privacy, /terms, /data-deletion, /sms-consent.
# NEXT_PUBLIC_LEGAL_LAST_UPDATED=March 30, 2026
#
# Canonical public legal URLs for OAuth/Twilio compliance forms (replace your domain):
# https://your-domain.com/privacy
# https://your-domain.com/terms
# https://your-domain.com/data-deletion
# https://your-domain.com/sms-consent
#
# Optional: protect Twilio status callback URL with a shared token query param.
# If set, Twilio callback URL should include:
# /api/webhooks/twilio/status?token=<TWILIO_WEBHOOK_TOKEN>
# TWILIO_WEBHOOK_TOKEN=your-random-webhook-token
#
# Optional/Recommended: Twilio request-signature verification for webhook authenticity.
# If set, /api/webhooks/twilio/status requires a valid X-Twilio-Signature.
# TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ── Cron secret ────────────────────────────────────────────────────────────────
# Any random string — used to protect /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
# Optional: alert when newest article in DB is older than this many hours (catalog ingest freshness; default 336).
# ENGAGEMENT_HEALTH_MAX_FRESHNESS_HOURS=336

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Client-side (used to render the widget on the login page)
# NEXT_PUBLIC_TURNSTILE_ENABLED: set to "1" or "true"
NEXT_PUBLIC_TURNSTILE_ENABLED=1
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xyour-turnstile-site-key-here
#
# Server-side (used to verify the token in POST /api/auth/email-link)
TURNSTILE_ENABLED=1
TURNSTILE_SECRET_KEY=0xyour-turnstile-secret-key-here

# ── Feed gap-fill modules (newspaper-style spacing) ───────────────────────────
# Client-visible flags for gap-fill between article rows (todo + generated art only).
NEXT_PUBLIC_FEED_GAP_FILL_ENABLED=true
NEXT_PUBLIC_FEED_GAP_MIN_PX=180
NEXT_PUBLIC_FEED_BETWEEN_GAP_MIN_PX=180
NEXT_PUBLIC_FEED_INLINE_GAP_MIN_PX=140
NEXT_PUBLIC_FEED_INLINE_MODULES_ENABLED=true
NEXT_PUBLIC_FEED_MODULE_POLICY=hybrid
NEXT_PUBLIC_FEED_FILLER_INTERVAL=4
# Optional mode switch; currently "generated_art" is used when weather is unavailable.
NEXT_PUBLIC_FEED_FILLER_FALLBACK=generated_art

# Server key for weather filler API route.
OPENWEATHER_API_KEY=your-openweather-key-here

# Google Places Autocomplete (no map) for profile weather location input.
# Restrict this browser key to your site origins + Places API only.
# Keep disabled until key restrictions are confirmed.
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-browser-places-key
# NEXT_PUBLIC_GOOGLE_PLACES_AUTOFILL_ENABLED=1
# Optional server-side Google key for strict validation/canonicalization in profile PATCH.
# If unset, server falls back to NEXT_PUBLIC_GOOGLE_PLACES_API_KEY.
# GOOGLE_MAPS_SERVER_API_KEY=your-server-google-key

# NASA APOD (optional; DEMO_KEY works with stricter rate limits)
# NASA_API_KEY=

# Spotify module (app-only client credentials, no user OAuth)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_MODULE_ENABLED=true
SPOTIFY_MODULE_MARKET=US
SPOTIFY_MODULE_DEFAULT_MOODS=chill,focus,uplifting

# Optional client-side module controls for feed rotation.
NEXT_PUBLIC_SPOTIFY_MODULE_ENABLED=true
NEXT_PUBLIC_WEATHER_MODULE_WEIGHT=3
NEXT_PUBLIC_SPOTIFY_MODULE_WEIGHT=1

# Recipe import allowlist (comma-separated hostnames), required for /api/creator/recipe-import.
# Example: allrecipes.com,foodnetwork.com,seriouseats.com
# RECIPE_IMPORT_ALLOWLIST=
# Optional: enable Claude-assisted fallback extraction.
# RECIPE_IMPORT_ENABLE_CLAUDE_FALLBACK=1
# Disable LLM-heavy game pool cron tasks by default.
# CRON_GAMES_LLM_ENABLED=0

# Ingest tuning
# INGEST_OVERHAUL_ENABLED=1
# INGEST_OVERHAUL_CANARY_CATEGORIES=Science & Discovery,Education
# INGEST_SOFT_DEADLINE_MS=55000
# INGEST_RUN_INPUT_TOKEN_CAP=25000
# INGEST_RUN_OUTPUT_TOKEN_CAP=8000
# Message Batches API (~50% lower token cost for expansion; async, often minutes). Discovery stays sync.
# Enabled by default in code. Set to 0 to force sync expansion.
# INGEST_MESSAGE_BATCH=0
# INGEST_BATCH_MAX_WAIT_MS=3600000
# INGEST_BATCH_POLL_MS=10000
# INGEST_BATCH_SYNC_FALLBACK_LIMIT=3
# INGEST_AUTO_LOCALE=global
# INGEST_DISCOVERY_PROVIDER=anthropic_web_search
# Keep rewriting OFF to ingest from RSS text directly (title/summary/content) when available.
# INGEST_REWRITE_ENABLED=0
# Provider pilot mode (no LLM discovery; expect lower yield):
# INGEST_DISCOVERY_PROVIDER=rss_seed_only
# RSS primary + Anthropic fallback mode:
# INGEST_DISCOVERY_PROVIDER=rss_seeded_primary
# RSS feed auto-disable threshold after repeated failures.
# RSS_FEED_AUTO_DISABLE_FAILURES=8
# RSS discovery pull limits per scheduler run.
# RSS_DISCOVERY_MAX_FEEDS=18
# Optional feed pool size for round-robin selection fairness across larger registries.
# RSS_DISCOVERY_FEED_POOL_LIMIT=100
# RSS_DISCOVERY_ITEMS_PER_FEED=8
# For sequential ingest moderation retries: max RSS XML depth window per feed.
# RSS_DISCOVERY_ITEMS_PER_FEED_MAX=24
# Staleness-driven scheduler refill: trigger ingest when newest tagged article in a category is older than this (hours).
# Default in code matches FRESHNESS_INGEST_HOURS in packages/domain when unset.
# INGEST_STALENESS_HOURS=3
# How many articles to request per category when only staleness triggers (capped by STOCK_TOP_UP_MAX_PER_RUN).
# INGEST_STALENESS_REFILL_COUNT=2
# Scheduler run budgets (see app/api/cron/scheduler/route.ts).
# CRON_INGEST_MAX_EXPANSIONS_PER_RUN=60
# CRON_INGEST_RUNTIME_BUDGET_MS=270000
# Temporary direction defaults (currently enabled in code):
# - seen-table reads
# - engagement scroll-depth telemetry
# Leave these commented for now. Revisit and explicitly set once product direction stabilizes.
# FEED_SEEN_TABLE_READS_ENABLED=1
# Include creator-submitted articles in /api/feed (default true when unset; use 0 to hide user_article only).
# FEED_INCLUDE_USER_SUBMITTED=1
# NEXT_PUBLIC_ENGAGEMENT_SCROLL_DEPTH_ENABLED=1
# Optional: disable distributed rate limiting or force in-memory buckets (see lib/security/rateLimit.ts).
# RATE_LIMIT_DISABLED=0
# RATE_LIMIT_USE_MEMORY=0
