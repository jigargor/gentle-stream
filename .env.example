# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional override for crossword clue calls (default: claude-sonnet-4-20250514).
# ANTHROPIC_CROSSWORD_MODEL=claude-3-5-sonnet-20241022
#
# Crossword clues: default is Wiktionary + Datamuse (no LLM). Set to use Claude:
# CROSSWORD_CLUES_SOURCE=anthropic

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# MUST be publishable (sb_publishable_...) or legacy anon JWT — never sb_secret_ or service_role.
# Supabase blocks secret keys from browsers (User-Agent); magic-link POST /auth/v1/otp returns 401.
# Legacy: anon JWT. New keys: Dashboard → Settings → API → Publishable.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here

# Server-only — secret key (sb_secret_...) or legacy service_role JWT. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: bypass auth middleware + login (local dev only). Never set in production.
# AUTH_DISABLED=1
# DEV_USER_ID=dev-local

# Production: OAuth redirect hint when SSR runs (dev ignores this and uses localhost:3000
# unless NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN is set). Set on Vercel to your canonical URL.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional OAuth/magic-link origin override when there is no browser (rare). The login UI
# uses window.location.origin for redirect_to so PKCE cookies match the address bar (LAN IP,
# non-default port, etc.). Supabase Redirect URLs must include that same origin, e.g.
# http://192.168.1.10:3000/**
#
# Optional explicit override (tunnels, etc.). Supabase must allow that URL in:
# Dashboard → Authentication → URL Configuration → Redirect URLs.
# Use http://localhost:3000/** (globstar) — http://localhost:3000/* matches only ONE path
# segment, so it does NOT match /auth/callback and Supabase falls back to Site URL (production).
# See https://supabase.com/docs/guides/auth/redirect-urls
# NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=http://localhost:3000

# Shown on /data-deletion as mailto for “delete my data” (Meta User data deletion URL, etc.).
# NEXT_PUBLIC_SUPPORT_EMAIL=you@yourdomain.com

# Optional legal docs date label used by /privacy, /terms, /data-deletion, /sms-consent.
# NEXT_PUBLIC_LEGAL_LAST_UPDATED=March 30, 2026
#
# Canonical public legal URLs for OAuth/Twilio compliance forms (replace your domain):
# https://your-domain.com/privacy
# https://your-domain.com/terms
# https://your-domain.com/data-deletion
# https://your-domain.com/sms-consent

# ── Cron secret ────────────────────────────────────────────────────────────────
# Any random string — used to protect /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Client-side (used to render the widget on the login page)
# NEXT_PUBLIC_TURNSTILE_ENABLED: set to "1" or "true"
NEXT_PUBLIC_TURNSTILE_ENABLED=1
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xyour-turnstile-site-key-here
#
# Server-side (used to verify the token in POST /api/auth/email-link)
TURNSTILE_ENABLED=1
TURNSTILE_SECRET_KEY=0xyour-turnstile-secret-key-here

# ── Feed gap-fill modules (newspaper-style spacing) ───────────────────────────
# Client-visible flags for weather filler placement.
NEXT_PUBLIC_FEED_GAP_FILL_ENABLED=true
NEXT_PUBLIC_FEED_GAP_MIN_PX=180
NEXT_PUBLIC_FEED_BETWEEN_GAP_MIN_PX=180
NEXT_PUBLIC_FEED_INLINE_GAP_MIN_PX=140
NEXT_PUBLIC_FEED_INLINE_MODULES_ENABLED=true
NEXT_PUBLIC_FEED_MODULE_POLICY=hybrid
NEXT_PUBLIC_FEED_FILLER_INTERVAL=4
# Optional mode switch; currently "generated_art" is used when weather is unavailable.
NEXT_PUBLIC_FEED_FILLER_FALLBACK=generated_art

# Server key for weather filler API route.
OPENWEATHER_API_KEY=your-openweather-key-here

# Spotify module (app-only client credentials, no user OAuth)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_MODULE_ENABLED=true
SPOTIFY_MODULE_MARKET=US
SPOTIFY_MODULE_DEFAULT_MOODS=chill,focus,uplifting

# Optional client-side module controls for feed rotation.
NEXT_PUBLIC_SPOTIFY_MODULE_ENABLED=true
NEXT_PUBLIC_WEATHER_MODULE_WEIGHT=3
NEXT_PUBLIC_SPOTIFY_MODULE_WEIGHT=1
