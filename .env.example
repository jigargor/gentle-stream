# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Public (anon) key — safe in the browser; required for Google + email sign-in
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: bypass auth middleware + login (local dev only). Never set in production.
# AUTH_DISABLED=1
# DEV_USER_ID=dev-local

# Production site URL (used in Supabase Auth redirect allow-list; optional if same as deploy URL)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Cron secret ────────────────────────────────────────────────────────────────
# Any random string — used to protect /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
