{
  "name": "gentle-stream",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "next dev",
    "dev-light": "cross-env DEV_LIGHT=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.ts,.tsx --max-warnings=9999",
    "ingest": "tsx scripts/ingest/run.ts",
    "ingest:all": "tsx scripts/ingest/run.ts --all",
    "ingest:tag": "tsx scripts/ingest/run.ts --tag-only",
    "articles:dedup-cleanup": "tsx -r dotenv/config scripts/articles-dedup-cleanup.ts dotenv_config_path=.env.local",
    "articles:remove-test-dedup": "tsx -r dotenv/config scripts/cleanup-test-dedup-articles.ts dotenv_config_path=.env.local",
    "validate:supabase-key": "tsx scripts/validate-supabase-public-key.ts",
    "games:word-pool": "tsx scripts/word-pool-ingest.ts",
    "games:blocked-crosswords": "tsx scripts/blocked-crossword-ingest.ts",
    "games:connections": "tsx -r dotenv/config scripts/connections-pool-ingest.ts dotenv_config_path=.env.local",
    "games:test-connections": "tsx scripts/test-connections.ts",
    "test:engagement:api": "tsx scripts/test-article-engagement-api.ts",
    "test:engagement:db": "tsx -r dotenv/config scripts/test-article-engagement-db.ts dotenv_config_path=.env.local",
    "test:reco:ranking": "tsx scripts/test-recommendation-ranking.ts",
    "test:reco:e2e": "tsx -r dotenv/config scripts/test-recommendation-e2e.ts dotenv_config_path=.env.local",
    "test:engagement:guardrails": "tsx scripts/test-engagement-guardrails.ts",
    "security:inventory": "tsx scripts/security-route-inventory.ts",
    "security:rls-audit": "tsx scripts/security-rls-boundary-audit.ts",
    "security:audit": "npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.43.4",
    "next": "16.2.1",
    "react": "^18",
    "react-dom": "^18",
    "react-intersection-observer": "^9.10.3",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.15.7",
    "typescript": "^5"
  }
}
