{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": false,
      "feature/*": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/tagger",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/translate",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/games",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/engagement-health",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/affinity-refresh",
      "schedule": "*/15 * * * *"
    }
  ]
}
