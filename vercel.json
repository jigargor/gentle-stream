{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/tagger",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/games",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/engagement-health",
      "schedule": "*/15 * * * *"
    }
  ]
}
